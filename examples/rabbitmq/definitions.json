  "bindings": [
    {"source": "demo.events", "vhost": "/demo", "destination": "orders.created", "destination_type": "queue", "routing_key": "order.created", "arguments": {}},
    {"source": "demo.events", "vhost": "/demo", "destination": "orders.cancelled", "destination_type": "queue", "routing_key": "order.cancelled", "arguments": {}},
    {"source": "demo.events", "vhost": "/demo", "destination": "orders.quorum", "destination_type": "queue", "routing_key": "order.quorum", "arguments": {}},
