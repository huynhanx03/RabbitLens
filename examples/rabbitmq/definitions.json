  "vhosts": [
    {
      "name": "/demo",
      "metadata": {
        "description": "RabbitLens primary demo workspace",
        "tags": ["demo", "rabbitlens"],
        "default_queue_type": "classic"
      }
    },
    {
      "name": "/upstream",
      "metadata": {
        "description": "Internal Federation and Shovel source",
        "tags": ["demo", "upstream"],
        "default_queue_type": "classic"
      }
    },
    {
      "name": "/restricted",
      "metadata": {
        "description": "Vhost isolation and authorization demo",
        "tags": ["demo", "restricted"],
        "default_queue_type": "classic"
      }
    }
  ],
  "permissions": [
    {"user": "admin", "vhost": "/demo", "configure": ".*", "write": ".*", "read": ".*"},
    {"user": "admin", "vhost": "/upstream", "configure": ".*", "write": ".*", "read": ".*"},
    {"user": "admin", "vhost": "/restricted", "configure": ".*", "write": ".*", "read": ".*"},
    {"user": "monitor", "vhost": "/demo", "configure": "^---$", "write": "^---$", "read": ".*"},
    {"user": "monitor", "vhost": "/upstream", "configure": "^---$", "write": "^---$", "read": ".*"},
    {"user": "monitor", "vhost": "/restricted", "configure": "^---$", "write": "^---$", "read": ".*"},
    {"user": "policymaker", "vhost": "/demo", "configure": ".*", "write": ".*", "read": ".*"},
    {"user": "policymaker", "vhost": "/upstream", "configure": ".*", "write": ".*", "read": ".*"},
    {"user": "operator", "vhost": "/demo", "configure": ".*", "write": ".*", "read": ".*"},
    {"user": "readonly", "vhost": "/demo", "configure": "^---$", "write": "^---$", "read": ".*"},
    {"user": "restricted", "vhost": "/restricted", "configure": ".*", "write": ".*", "read": ".*"},
    {"user": "bridge", "vhost": "/demo", "configure": ".*", "write": ".*", "read": ".*"},
    {"user": "bridge", "vhost": "/upstream", "configure": ".*", "write": ".*", "read": ".*"}
  ],
  "topic_permissions": [],
  "parameters": [
    {
      "component": "federation-upstream",
      "name": "demo-upstream",
      "vhost": "/demo",
      "value": {
        "uri": "amqp://bridge:rabbitlens-demo@rabbitmq:5672/%2Fupstream",
        "exchange": "upstream.events",
        "ack-mode": "on-confirm",
        "max-hops": 1,
        "reconnect-delay": 1,
        "trust-user-id": false
      }
    },
    {
      "component": "shovel",
      "name": "upstream-to-demo",
      "vhost": "/demo",
      "value": {
        "src-uri": "amqp://bridge:rabbitlens-demo@rabbitmq:5672/%2Fupstream",
        "src-queue": "shovel.source",
        "src-prefetch-count": 100,
        "src-delete-after": "never",
        "dest-uri": "amqp://bridge:rabbitlens-demo@rabbitmq:5672/%2Fdemo",
        "dest-exchange": "demo.events",
        "dest-exchange-key": "shoveled.demo",
        "dest-add-forward-headers": true,
        "ack-mode": "on-confirm",
        "reconnect-delay": 1
      }
    },
    {
      "component": "operator_policy",
      "name": "demo-queue-guardrails",
      "vhost": "/demo",
      "value": {
        "pattern": "^(orders\\.created|orders\\.cancelled|notifications\\.email|shovel\\.received)$",
        "definition": {"max-length": 10000},
        "priority": 100,
        "apply-to": "queues"
      }
    },
    {
      "component": "vhost-limits",
      "name": "limits",
      "vhost": "/demo",
      "value": {"max-connections": 100, "max-queues": 100}
    },
    {
      "component": "vhost-limits",
      "name": "limits",
      "vhost": "/upstream",
      "value": {"max-connections": 50, "max-queues": 50}
    },
    {
      "component": "vhost-limits",
      "name": "limits",
      "vhost": "/restricted",
      "value": {"max-connections": 20, "max-queues": 20}
    }
  ],
  "global_parameters": [
    {"name": "cluster_name", "value": "rabbitlens-demo"}
  ],
  "policies": [
    {
      "vhost": "/demo",
      "name": "orders-dead-letter",
      "pattern": "^(orders\\.created|orders\\.cancelled)$",
      "apply-to": "queues",
      "definition": {
        "dead-letter-exchange": "demo.dlx",
        "dead-letter-routing-key": "order.dead"
      },
      "priority": 20
    },
    {
      "vhost": "/demo",
      "name": "federate-demo-events",
      "pattern": "^federated\\.events$",
      "apply-to": "exchanges",
      "definition": {"federation-upstream": "demo-upstream"},
      "priority": 20
    }
  ],
  "queues": [
    {"name": "orders.created", "vhost": "/demo", "durable": true, "auto_delete": false, "arguments": {"x-queue-type": "classic"}, "type": "classic"},
    {"name": "orders.cancelled", "vhost": "/demo", "durable": true, "auto_delete": false, "arguments": {"x-queue-type": "classic"}, "type": "classic"},
