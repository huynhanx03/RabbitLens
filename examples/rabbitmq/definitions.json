    {"source": "activity-log", "vhost": "/demo", "destination": "activity-log", "destination_type": "queue", "routing_key": "activity.#", "arguments": {}},
    {"source": "pentest.logs", "vhost": "/demo", "destination": "pentest.logs", "destination_type": "queue", "routing_key": "", "arguments": {}},
