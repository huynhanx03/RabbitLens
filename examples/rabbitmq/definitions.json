    {"name": "audit.stream", "vhost": "/demo", "durable": true, "auto_delete": false, "arguments": {"x-queue-type": "stream"}, "type": "stream"},
    {"name": "shovel.received", "vhost": "/demo", "durable": true, "auto_delete": false, "arguments": {"x-queue-type": "classic"}, "type": "classic"},
    {"name": "pentest.response", "vhost": "/demo", "durable": true, "auto_delete": false, "arguments": {"x-queue-type": "classic"}, "type": "classic"},
    {"name": "activity-log", "vhost": "/demo", "durable": true, "auto_delete": false, "arguments": {"x-queue-type": "classic"}, "type": "classic"},
    {"name": "pentest.logs", "vhost": "/demo", "durable": true, "auto_delete": false, "arguments": {"x-queue-type": "classic"}, "type": "classic"},
    {"name": "pentest.tracking", "vhost": "/demo", "durable": true, "auto_delete": false, "arguments": {"x-queue-type": "classic"}, "type": "classic"},
    {"name": "shovel.source", "vhost": "/upstream", "durable": true, "auto_delete": false, "arguments": {"x-queue-type": "classic"}, "type": "classic"},
    {"name": "restricted.queue", "vhost": "/restricted", "durable": true, "auto_delete": false, "arguments": {"x-queue-type": "classic"}, "type": "classic"}
  ],
  "exchanges": [
