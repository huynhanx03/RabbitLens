    {"name": "credit.request", "vhost": "/demo", "type": "direct", "durable": true, "auto_delete": false, "internal": false, "arguments": {}},
    {"name": "upstream.events", "vhost": "/upstream", "type": "topic", "durable": true, "auto_delete": false, "internal": false, "arguments": {}},
    {"name": "restricted.events", "vhost": "/restricted", "type": "direct", "durable": true, "auto_delete": false, "internal": false, "arguments": {}}
