    {"source": "demo.events", "vhost": "/demo", "destination": "shovel.received", "destination_type": "queue", "routing_key": "shoveled.#", "arguments": {}},
    {"source": "demo.direct", "vhost": "/demo", "destination": "notifications.email", "destination_type": "queue", "routing_key": "email.send", "arguments": {}},
