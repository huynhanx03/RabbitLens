# RabbitLens deployment for an existing RabbitMQ Management API.
#
# Copy this file to .env, then update the values for your environment:
#   cp deploy/.env.example deploy/.env
#   docker compose --env-file deploy/.env -f deploy/compose.yaml up -d --build

# RabbitLens UI
RABBITLENS_IMAGE=rabbitlens:local
RABBITLENS_BIND_ADDRESS=127.0.0.1
RABBITLENS_PORT=8080

# Existing RabbitMQ Management API.
# Use host.docker.internal when RabbitMQ runs on the Docker host.
# Use a DNS name or service name when RabbitMQ runs on a reachable network.
RABBITMQ_MANAGEMENT_SCHEME=http
RABBITMQ_MANAGEMENT_HOST=host.docker.internal
RABBITMQ_MANAGEMENT_PORT=15672

# Docker embedded DNS works for normal Compose networks.
# Change this only if your container runtime uses a different resolver.
RABBITLENS_DNS_RESOLVER=127.0.0.11
RABBITLENS_DNS_TTL=10s
RABBITLENS_DNS_IPV6=off
